   "source": [
    "from callbacks import SaveArtifactsEveryNEpochs\n",
    "\n",
    "# ====== text->ids для модели ======\n",
    "# Мы уже обучаемся на \"фонемных строках\" (с паузами), но тестовые фразы сейчас обычные.\n",
    "# Поэтому для тестовых фраз мы прогоняем тот же пайплайн:\n",
    "from phonemize_ru import cleanup_phonemes\n",
    "from prosody import build_features, pause_ms_to_token\n",
    "\n",
    "def prepare_test_phrase_to_phonemes(text: str) -> str:\n",
    "    t = add_pauses_to_text(text)         # слова + паузы\n",
    "    ph = cleanup_phonemes(phonemize_ru([t])[0])\n",
    "    return ph\n",
    "\n",
    "def text_to_model_inputs(text: str) -> torch.LongTensor:\n",
    "    ph = prepare_test_phrase_to_phonemes(text)\n",
    "    ids = tokenizer.text_to_ids(ph)\n",
    "    return torch.LongTensor(ids).unsqueeze(0)  # (1, T)\n",
    "\n",
    "# ====== inference ======\n",
    
    "def infer_fn(text_ids: torch.LongTensor) -> dict:\n",
    "    # некоторые версии требуют lens\n",
    "    try:\n",
    "        out = model.inference(text_ids)\n",
    "        return out\n",
    "    except TypeError:\n",
    "        lens = torch.LongTensor([text_ids.shape[1]]).to(text_ids.device)\n",
    "        out = model.inference(text_ids, lens)\n",
    "        return out\n",
    "\n",
    "# ====== как сохранять checkpoint ======\n",
    "def get_checkpoint_payload():\n",
    "    # сохраняем model.state_dict + config + tokenizer info\n",
    "    return {\n",
    "        \"model\": model.state_dict(),\n",
    "        \"config\": config.to_dict() if hasattr(config, \"to_dict\") else dict(config),\n",
    "        \"tokenizer\": None,   # tokenizer объект не сериализуем\n",
    "        \"epoch\": getattr(trainer, \"epoch\", None) if \"trainer\" in globals() else None,\n",
    "    }\n",
    "\n",
    "CKPT_DIR = os.path.join(RUNS_DIR, \"manual_ckpts\")\n",
    "os.makedirs(CKPT_DIR, exist_ok=True)\n",
    "\n",
    "callback = SaveArtifactsEveryNEpochs(\n",
    "    every_n_epochs=1,\n",
    "    results_dir=RESULTS_DIR,\n",
    "    test_phrases=TEST_PHRASES,\n",
    "    text_to_model_inputs=text_to_model_inputs,\n",
    "    infer_fn=infer_fn,\n",
    "    ap=ap,\n",
    "    sample_rate=SAMPLE_RATE,\n",
    "    device=device,\n",
    "    get_checkpoint_payload=get_checkpoint_payload,\n",
    "    ckpt_dir=CKPT_DIR\n",
    ")\n",
    "\n",
    "print(\"Callback ready:\", callback.results_dir)\n"
   ]
  },
