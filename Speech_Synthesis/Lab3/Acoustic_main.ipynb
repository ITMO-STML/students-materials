   "source": [
    "cat_cols = [\"word\", \"prev_word\", \"next_word\", \"punct_after\"]\n",
    "num_cols = [\"word_len\", \"is_capital\", \"word_pos\", \"words_after\"]\n",
    "\n",
    "for c in cat_cols:\n",
    "    df[c] = df[c].fillna(\"\").astype(str)\n",
    "\n",
    "X = df[cat_cols + num_cols]\n",
    "y_cls = df[\"has_pause\"].astype(int)\n",
    "y_reg = df[\"pause_ms\"].astype(int)\n",
    "\n",
    "X_train, X_test, y_cls_train, y_cls_test, y_reg_train, y_reg_test = train_test_split(\n",
    "    X, y_cls, y_reg, test_size=0.2, random_state=SEED, stratify=y_cls\n",
    ")\n",
    "\n",
    "clf_pause = CatBoostClassifier(\n",
    "    iterations=400,\n",
    "    depth=8,\n",
    "    learning_rate=0.1,\n",
    "    loss_function=\"Logloss\",\n",
    "    cat_features=cat_cols,\n",
    "    verbose=100,\n",
    "    random_seed=SEED\n",
    ")\n",
    "\n",
    "reg_pause = CatBoostRegressor(\n",
    "    iterations=400,\n",
    "    depth=8,\n",
    "    learning_rate=0.1,\n",
    "    loss_function=\"RMSE\",\n",
    "    cat_features=cat_cols,\n",
    "    verbose=100,\n",
    "    random_seed=SEED\n",
    ")\n",
    "\n",
    "clf_pause.fit(X_train, y_cls_train)\n",
    "reg_pause.fit(X_train, y_reg_train)\n",
    "\n",
    "print(\"Done catboost.\")\n"
   ]
