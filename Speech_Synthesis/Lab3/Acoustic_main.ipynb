   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "ASCII phonemes example: InAgd'a amjirjik'antsy, tSj'aXi sAAtj'etSjistvjinnjikjI. Anj'i zvAnj'iLjI j'ej p'o tjiLjif'onu.\n"
     ]
    }
   ],
   "source": [
    "# ===== IPA -> ASCII PHONEME MAPPING =====\n",
    "\n",
    "IPA2ASCII = {\n",
    "    # vowels\n",
    "    \"ɪ\": \"I\",\n",
    "    \"i\": \"i\",\n",
    "    \"e\": \"e\",\n",
    "    \"ɛ\": \"E\",\n",
    "    \"a\": \"a\",\n",
    "    \"ɑ\": \"a\",\n",
    "    \"o\": \"o\",\n",
    "    \"u\": \"u\",\n",
    "    \"ʌ\": \"A\",\n",
    "    \"ə\": \"e\",\n",
    "    \"ɨ\": \"Y\",\n",
    "\n",
    "    # consonants\n",
    "    \"ɡ\": \"g\",\n",
    "    \"ʃ\": \"S\",\n",
    "    \"ʒ\": \"Z\",\n",
    "    \"ɕ\": \"X\",\n",
    "    \"ʑ\": \"Q\",\n",
    "    \"ʧ\": \"C\",\n",
    "    \"ʤ\": \"J\",\n",
    "    \"ŋ\": \"N\",\n",
    "    \"ɭ\": \"L\",\n",
    "\n",
    "    # modifiers / stress\n",
    "    \"ʲ\": \"j\",\n",
    "    \"ˈ\": \"'\",\n",
    "    \"ˌ\": \",\",\n",
    "\n",
    "    # garbage / punctuation from upstream\n",
    "    '\"': \"\",\n",
    "    \"^\": \"\",\n",
    "}\n",
    "\n",
    "def ipa_to_ascii(ph: str) -> str:\n",
    "    ph = ph.replace(\"\\n\", \" \").strip()   # <-- КРИТИЧНО\n",
    "    out = []\n",
    "    for ch in ph:\n",
    "        out.append(IPA2ASCII.get(ch, ch))\n",
    "    return \"\".join(out)\n",
    "\n",
    "train_ph = [ipa_to_ascii(p) for p in train_ph]\n",
    "val_ph   = [ipa_to_ascii(p) for p in val_ph]\n",
    "\n",
    "print(\"ASCII phonemes example:\", train_ph[0])"
   ]
  },
