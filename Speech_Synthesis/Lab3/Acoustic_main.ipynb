   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Иногда американцы, чаще | соотечественники. Они звонили ей по телефону. |\n"
     ]
    }
   ],
   "source": [
    "from prosody import build_features, PausePredictor, pause_ms_to_token\n",
    "from phonemize_ru import phonemize_ru, cleanup_phonemes, normalize_ru\n",
    "\n",
    "pause_predictor = PausePredictor(clf=clf_pause, reg=reg_pause)\n",
    "\n",
    "def add_pauses_to_text(text: str) -> str:\n",
    "    \"\"\"\n",
    "    text -> \"текст с | после некоторых слов\" (на уровне слов)\n",
    "    \"\"\"\n",
    "    text = normalize_ru(text)\n",
    "    feats = build_features(text)\n",
    "\n",
    "    if len(feats) == 0:\n",
    "        return text\n",
    "\n",
    "    pause_ms = pause_predictor.predict_pause_ms(feats)\n",
    "\n",
    "    # склеим обратно по словам, добавляя \"|\" после слова\n",
    "    out_words = []\n",
    "    for i, row in feats.iterrows():\n",
    "        w = row[\"word\"]\n",
    "        punct = row[\"punct_after\"]\n",
    "        tok = pause_ms_to_token(pause_ms[i], unit_ms=200, max_tokens=8)\n",
    "        if punct:\n",
    "            out_words.append(w + punct)\n",
    "        else:\n",
    "            out_words.append(w)\n",
    "        if tok:\n",
    "            out_words.append(tok)\n",
    "\n",
    "    return \" \".join(out_words)\n",
    "\n",
    "# готовим тексты для фонемизации\n",
