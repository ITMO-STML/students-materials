    "# ====== путь к Jerome.Result.xml (обнови если нужно) ======\n",
    "JEROME_XML = os.path.join(ROOT_DIR, \"Jerome.Result.xml\")\n",
    "\n",
    "from catboost import CatBoostClassifier, CatBoostRegressor\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "import xml.etree.ElementTree as ET\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "def parse_jerome_for_pauses(xml_path: str) -> pd.DataFrame:\n",
    "    tree = ET.parse(xml_path)\n",
    "    root = tree.getroot()\n",
    "\n",
    "    rows = []\n",
    "    for sent in root.iter(\"sentence\"):\n",
    "        elements = list(sent)\n",
    "        words = []\n",
    "        # собираем слова + паузы после них\n",
    "        for i, el in enumerate(elements):\n",
    "            if el.tag != \"word\":\n",
    "                continue\n",
    "            w = el.attrib.get(\"original\", \"\")\n",
    "            if not w:\n",
    "                continue\n",
    "\n",
    "            # ищем паузу после этого слова\n",
    "            pause_ms = 0\n",
    "            punct_after = \"\"\n",
    "            # пробуем найти content с пунктуацией рядом (приближенно)\n",
    "            if i + 1 < len(elements) and elements[i + 1].tag == \"content\":\n",
    "                punct_after = elements[i + 1].attrib.get(\"PunktEnd\", \"\") or \"\"\n",
    "\n",
    "            for j in range(i + 1, len(elements)):\n",
    "                if elements[j].tag == \"pause\":\n",
    "                    pause_ms = int(elements[j].attrib.get(\"time\", \"0\") or \"0\")\n",
    "                    break\n",
    "                if elements[j].tag == \"word\":\n",
    "                    break\n",
    "\n",
    "            words.append((w, pause_ms, punct_after))\n",
    "\n",
    "        # признаки по словам в предложении\n",
    "        for k in range(len(words)):\n",
    "            w, pause_ms, punct_after = words[k]\n",
    "            prev_word = words[k - 1][0] if k > 0 else \"\"\n",
    "            next_word = words[k + 1][0] if k + 1 < len(words) else \"\"\n",
    "            rows.append({\n",
    "                \"word\": w,\n",
    "                \"prev_word\": prev_word,\n",
    "                \"next_word\": next_word,\n",
    "                \"punct_after\": str(punct_after),\n",
    "                \"word_len\": len(w),\n",
    "                \"is_capital\": int(w[:1].isupper()),\n",
    "                \"word_pos\": k,\n",
    "                \"words_after\": len(words) - k - 1,\n",
    "                \"has_pause\": int(pause_ms > 0),\n",
    "                \"pause_ms\": int(pause_ms),\n",
    "            })\n",
    "    return pd.DataFrame(rows)\n",
    "\n",
    "df = parse_jerome_for_pauses(JEROME_XML)\n",
    "print(\"Jerome rows:\", len(df))\n",
    "display(df.head())\n"
   ]
  },
