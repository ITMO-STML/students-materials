    "def duration_sec(path):\n",
    "    y, sr = librosa.load(path, sr=None)\n",
    "    return len(y) / sr\n",
    "\n",
    "def normalize_text(text: str) -> str:\n",
    "    text = text.lower()\n",
    "    text = re.sub(r\"[^а-яё0-9.,!?;:\\-— ]+\", \"\", text)\n",
    "    text = re.sub(r\"\\s+\", \" \", text).strip()\n",
    "    return text\n",
    "\n",
    "clean_samples = []\n",
    "\n",
    "from tqdm import tqdm\n",
    "\n",
    "clean_samples = []\n",
    "\n",
    "with open(META_SRC, encoding=\"utf-8\") as f:\n",
    "    for line in tqdm(f):\n",
    "        line = line.strip()\n",
    "        if not line:\n",
    "            continue\n",
    "\n",
    "        parts = line.split(\"|\")\n",
    "\n",
    "        # минимум: wav + текст\n",
    "        if len(parts) < 2:\n",
    "            continue\n",
    "\n",
    "        wav_id = parts[0]\n",
