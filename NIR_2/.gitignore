hf_cache/
.cache/
ollama_home/
models/

# ──────────────────────────────────────────────────────────────────────
# Данные
# ──────────────────────────────────────────────────────────────────────
# Базовые корпуса — грузятся из HF, в репо не нужны
data/rubq/
data/mmarco/
data/miracl/

# Большие jsonl с прогонов сборки негативов/позитивов
data/negatives_*.jsonl
data/positives_*.jsonl
data/*_full.jsonl
data/*.tsv.gz
data/*.parquet

# Сгенерированные training data в data/train/ — большие, легко перегенерить
# через 07_build_train_data.py. НО оставляем split.json, summary.json, report.md
# (мелкие, фиксируют состав ablation grid для воспроизводимости).
data/train/*.jsonl

# Но рукотворный sanity-набор оставляем в git
!data/sanity_examples.jsonl

